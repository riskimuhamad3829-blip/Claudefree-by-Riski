def start_web_server():
    port = 8080
    handler = ClaudefreeWebHandler
    
    # Supaya bind address bebas (bisa diakses via localhost)
    socketserver.TCPServer.allow_reuse_address = True
    while True:
        try:
            httpd = socketserver.TCPServer(("", port), handler)
            break
        except OSError:
            port += 1
            
    print(f"\n{Colors.BOLD}{Colors.GREEN}✔ Claudefree Web OS Engine Started!{Colors.END}")
    print(f"{Colors.BOLD}🌐 Buka link ini di browsermu: {Colors.CYAN}http://localhost:{port}{Colors.END}")
    print(f"{Colors.YELLOW}   (Tekan Ctrl+C untuk mematikan server dan kembali ke terminal){Colors.END}\n")
    
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print(f"\n\n{Colors.RED}Mematikan Web Server...{Colors.END}")
        httpd.server_close()
        time.sleep(0.5)

