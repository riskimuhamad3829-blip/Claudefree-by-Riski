def ask_claude(model, message):
    if model == "opus":
        url = "https://api.synoxcloud.xyz/ai-chat/claude-opus-4.8?pesan="
    else:
        url = "https://api.synoxcloud.xyz/ai-chat/claude-sonnet-4.6?pesan="
    
    encoded_message = urllib.parse.quote(message)
    full_url = url + encoded_message
    
    try:
        req = urllib.request.Request(full_url, headers={'User-Agent': 'ClaudefreeCLI/3.0'})
        with urllib.request.urlopen(req, timeout=45) as response:
            data = json.loads(response.read().decode('utf-8'))
            if data.get("status"):
                return data["result"]["reply"]
            else:
                return f"API Error: {data}"
    except Exception as e:
        return f"Network Error: {e}"

