def handle_slash_command(command):
    global CURRENT_MODEL
    parts = command.strip().split()
    cmd = parts[0].lower()
    
    if cmd == "/model":
        if len(parts) > 1:
            new_model = parts[1].lower()
            if new_model in ["sonnet", "opus"]:
                CURRENT_MODEL = new_model
                print(f"{Colors.GREEN}✔ Context switched to model: {Colors.BOLD}{CURRENT_MODEL.upper()}{Colors.END}")
            else:
                print(f"{Colors.RED}✖ Invalid model '{new_model}'. Options: sonnet, opus{Colors.END}")
        else:
            print(f"Active model: {Colors.BOLD}{CURRENT_MODEL.upper()}{Colors.END}. Usage: /model <sonnet|opus>")
    elif cmd == "/clear":
        clear_screen()
        print_logo()
    elif cmd == "/web":
        start_web_server()
        # Habis matikan web server, clear screen dan print logo lagi
        clear_screen()
        print_logo()
    elif cmd == "/sysinfo":
        print(f"\n{Colors.BOLD}System Information:{Colors.END}")
        print(f"  Core Version : 3.0.0-linux-x64 (Web-Enabled)")
        print(f"  Active Model : {CURRENT_MODEL.upper()}")
        print(f"  Connection   : Secure (Synoxcloud API)")
        print(f"  Uptime       : Active\n")
    elif cmd == "/help":
        show_help()
    elif cmd in ["/exit", "/quit"]:
        print(f"\n{Colors.BLUE}Terminating session... Goodbye.{Colors.END}")
        sys.exit(0)
    else:
        print(f"{Colors.RED}✖ Unknown command '{cmd}'. Type /help.{Colors.END}")

def type_text(text, delay=0.005):
    for char in text:
        sys.stdout.write(char)
        sys.stdout.flush()
        time.sleep(delay)
    print()

def main():
    global CURRENT_MODEL
    
    if len(sys.argv) > 1:
        message = " ".join(sys.argv[1:])
        reply = ask_claude(CURRENT_MODEL, message)
        print(reply)
        sys.exit(0)
        
    animate_loading()
    print_logo()
    
    while True:
        try:
            prompt = f"\n{Colors.BOLD}{Colors.GREEN}┌──(you㉿claudefree)-[{Colors.CYAN}{CURRENT_MODEL}{Colors.GREEN}]\n└─${Colors.END} "
            user_input = input(prompt)
            
            if not user_input.strip():
                continue
                
            if user_input.startswith("/"):
                handle_slash_command(user_input)
                continue
            
            sys.stdout.write(f"{Colors.YELLOW}⠋ Fetching data...{Colors.END}\r")
            sys.stdout.flush()
            
            reply = ask_claude(CURRENT_MODEL, user_input)
            
            sys.stdout.write(" "*30 + "\r")
            sys.stdout.flush()
            
            print(f"{Colors.BOLD}{Colors.MAGENTA}╭─[Claude {CURRENT_MODEL.capitalize()}]{Colors.END}")
            
            lines = reply.split('\n')
            for line in lines:
                sys.stdout.write(f"{Colors.BOLD}{Colors.MAGENTA}│{Colors.END} ")
                type_text(line, delay=0.003)
            
            print(f"{Colors.BOLD}{Colors.MAGENTA}╰────────────────────────────────────────{Colors.END}")
            
        except (KeyboardInterrupt, EOFError):
            print(f"\n\n{Colors.BLUE}Session interrupted. Goodbye.{Colors.END}")
            break
        except Exception as e:
            print(f"\n{Colors.RED}✖ Critical Error: {e}{Colors.END}")

if __name__ == "__main__":
    main()
