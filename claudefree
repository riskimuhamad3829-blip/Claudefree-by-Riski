def animate_loading():
    clear_screen()
    boot_msgs = [
        "Initializing Claudefree kernel...",
        "Loading AI models and weights into memory...",
        "Establishing secure connection to Synoxcloud...",
        "Verifying API endpoints...",
        "Starting Web Server Daemon (standby)...",
        "Mounting interactive terminal environment..."
    ]
    
    for msg in boot_msgs:
        sys.stdout.write(f"{Colors.BOLD}{Colors.GREEN}[ OK ]{Colors.END} {msg}\n")
        time.sleep(random.uniform(0.1, 0.3))
    
    print()
    total = 50
    for i in range(total + 1):
        percent = int((i / total) * 100)
        bar = '=' * i + ('>' if i < total else '') + ' ' * (total - i - (1 if i < total else 0))
        sys.stdout.write(f"\r{Colors.CYAN}Booting System: [{bar}] {percent}%{Colors.END}")
        sys.stdout.flush()
        time.sleep(random.uniform(0.005, 0.02))
    
    time.sleep(0.3)
    clear_screen()

